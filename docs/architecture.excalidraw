      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Invariants:\n• Solid arrows = on-chain token/value flow.  Dashed arrows = off-chain authorised calls.\n• Agent EOAs never hold user funds — only call executeAction on their own strategy.\n• Each strategy is an EIP-1167 clone with its own approvals; compromise is blast-radius-limited.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "Invariants:\n• Solid arrows = on-chain token/value flow.  Dashed arrows = off-chain authorised calls.\n• Agent EOAs never hold user funds — only call executeAction on their own strategy.\n• Each strategy is an EIP-1167 clone with its own approvals; compromise is blast-radius-limited.",
      "lineHeight": 1.25
    }
  ],
